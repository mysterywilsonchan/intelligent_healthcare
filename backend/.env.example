# ===== 大模型 Provider 配置 =====
# 默认使用的 provider，可选：doubao | qwen | deepseek | mock
# 无任何 API key 时建议用 mock，可离线演示与测试
LLM_PROVIDER=doubao

# --- 豆包 / 火山方舟 Ark（默认）---
# API Key 在火山引擎方舟控制台获取；DOUBAO_MODEL 通常填接入点 ID（ep-xxxx）或模型名
DOUBAO_API_KEY=
DOUBAO_MODEL=doubao-seed-1-8-251228
DOUBAO_VISION_MODEL=doubao-seed-1-8-251228

# --- 阿里 Qwen / DashScope（OpenAI 兼容模式）---
QWEN_API_KEY=
QWEN_MODEL=qwen-plus
QWEN_VISION_MODEL=qwen-vl-max

# --- DeepSeek ---
# DeepSeek 当前文本接口无视觉能力，上传图片时会自动回退到默认视觉 provider
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# 视觉任务回退的 provider（当所选 provider 不支持视觉时使用）
VISION_FALLBACK_PROVIDER=doubao

# LLM 通用参数
LLM_TEMPERATURE=0.4
LLM_TIMEOUT=60
